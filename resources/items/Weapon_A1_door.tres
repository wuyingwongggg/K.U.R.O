"SpeedMultiplierPerStack": 0.75
}

[resource]
script = ExtResource("1_item_definition")
ItemId = "weapon_a1_door"
DisplayName = "A1 门板"
Description = "坚固的门板，可用于格挡大范围攻击，但极其笨重。"
Icon = ExtResource("3_door_icon")
Category = "Weapon"
MaxStackSize = 1
Tags = PackedStringArray("tag_weapon")
AttributeEntries = Array[Resource]([SubResource("Attribute_AttackPower")])
DurabilityConfig = SubResource("Durability_Config")
EffectEntries = Array[Resource]([SubResource("Effect_Slow")])
